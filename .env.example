OKTA_DOMAIN=https://your-org.okta.com

# OIDC Web App 
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/auth/callback

# AI Agent (the wlp... client, used for the XAA token exchange)
AGENT_CLIENT_ID=
AGENT_KEY_ID=
AGENT_PRIVATE_KEY_FILE=./agent-key.pem

# Custom Authorization Server (the resource AS — just the asid)
CUSTOM_AS_ID=
XAA_SCOPE=xaa:read

RESOURCE_API_URL=http://localhost:8081/api/me
RESOURCE_PORT=8081
PORT=3000

SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars
NODE_ENV=development
